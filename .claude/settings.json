{
  "permissions": {
    "allow": [
      "Bash(npx --yes vercel whoami)",
      "Bash(npx --yes vercel --prod --yes)",
      "Bash(git commit -m ' *)",
      "Bash(git add *)"
    ]
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "handoff": {
      "source": {
        "source": "github",
        "repo": "thepushkarp/handoff"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "skill-creator@claude-plugins-official": true,
    "handoff@handoff": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "caveman@caveman": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FP=$(cat | jq -r '.tool_input.file_path // .tool_input.notebook_path // empty'); if echo \"$FP\" | grep -Eq '/src/.*\\.(ts|tsx)$'; then cd \"/Users/gale/Library/Mobile Documents/com~apple~CloudDocs/poke_fantasy\" || exit 0; OUT=$(npm run verify 2>&1); CODE=$?; if [ $CODE -ne 0 ]; then echo \"$OUT\" | tail -150; exit 2; fi; fi",
            "timeout": 180,
            "statusMessage": "코드 검증 중 (typecheck/test/lint/unused)...",
            "asyncRewake": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff\" bash \"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff/scripts/precompact-append-handoff.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff\" bash \"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff/scripts/sessionstart-inject-latest-handoff.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff\" bash \"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff/scripts/userpromptsubmit-marker-and-fallback-inject.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff\" bash \"${CLAUDE_PROJECT_DIR}/.claude/vendor/handoff/scripts/stop-enforce-model-sections.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
